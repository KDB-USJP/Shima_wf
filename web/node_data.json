  "nodes": [

    { "id": "master-prompt", "name": "Master Prompt", "category": "Conditioning",
      "description": "Multi-model-aware dual-prompt management node. Handles positive and negative conditioning for SD1.5, SDXL, SD3, Flux, AuraFlow, and HunyuanDiT via independent CLIP-L, CLIP-G, and T5 text encoders with per-encoder weight sliders.",
      "image": null,
      "inputs": [
        {"name": "clip", "type": "CLIP", "desc": "CLIP model for text encoding"},
        {"name": "modelcitizen", "type": "BNDL", "desc": "Model Citizen bundle (auto-extracts CLIP)"},
        {"name": "positive", "type": "STRING", "desc": "Main positive prompt"},
        {"name": "negative", "type": "STRING", "desc": "Main negative prompt"},
        {"name": "positive_l / negative_l", "type": "STRING", "desc": "CLIP-L positive/negative (style, detail)"},
        {"name": "positive_g / negative_g", "type": "STRING", "desc": "CLIP-G positive/negative (subject, composition)"},
        {"name": "positive_t5 / negative_t5", "type": "STRING", "desc": "T5 positive/negative (complex language, Flux/SD3)"}
      ],
      "widgets": [
        {"name": "model_type", "type": "COMBO", "desc": "sdxl, sd1.5, sd3, flux, auraflow, hunyuan"},
        {"name": "clip_l_weight", "type": "FLOAT", "desc": "CLIP-L encoder weight (0.0–10.0)"},
        {"name": "clip_g_weight", "type": "FLOAT", "desc": "CLIP-G encoder weight (0.0–10.0)"},
        {"name": "t5_weight", "type": "FLOAT", "desc": "T5 encoder weight (0.0–10.0)"},
        {"name": "show_used_values", "type": "BOOLEAN", "desc": "Display passed values"},
        {"name": "allow_external_linking", "type": "BOOLEAN", "desc": "Topbar UE toggle"}
      ],
      "outputs": [
        {"name": "positive", "type": "CONDITIONING", "desc": "Encoded positive conditioning"},
        {"name": "negative", "type": "CONDITIONING", "desc": "Encoded negative conditioning"},
        {"name": "masterprompt.bndl", "type": "BNDL", "desc": "Bundle with both conditionings"}
      ]
    },

